{
  "name": "ai-homework-review-api",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --env-file=.env --watch --import tsx src/server.ts",
    "start": "node --env-file=.env dist/api/src/server.js",
    "build": "tsc -p tsconfig.json && npm run build:function",
    "build:function": "node scripts/build-function.mjs",
    "test": "vitest run"
  },
  "dependencies": {
    "@alicloud/openapi-client": "^0.4.15",
    "@alicloud/sts20150401": "^1.2.0",
    "@napi-rs/canvas": "^0.1.66",
    "ali-oss": "^6.23.0",
    "hono": "^4.7.0",
    "jose": "^5.10.0",
    "pdfjs-dist": "^4.10.38",
    "proxy-agent": "^5.0.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "esbuild": "^0.28.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  }
}
