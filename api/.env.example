JWT_SECRET=replace-with-a-long-secret
ALLOWED_ORIGINS=https://demo.example.com,https://masoncat.github.io,http://localhost:5173,http://127.0.0.1:5173
INVITE_CODES=demo-code
HUMAN_CHECK_TOKEN=pass-human-check
PUBLIC_BASE_URL=https://demo.example.com
OBJECT_STORE_DRIVER=memory
OSS_BUCKET=
OSS_REGION=
# Example: https://examplebucket.oss-cn-hangzhou.aliyuncs.com
OSS_ENDPOINT=
# Required for local STS/OOS testing. In Function Compute, runtime credentials can replace them.
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_SECURITY_TOKEN=
OSS_UPLOAD_PREFIX=uploads/demo
OSS_UPLOAD_EXPIRES_IN_SECONDS=300
OSS_MAX_SIZE_BYTES=10485760
OSS_STS_ROLE_ARN=
OSS_STS_SESSION_NAME=ai-homework-review-upload
OSS_STS_DURATION_SECONDS=900
# Example: sts.cn-hangzhou.aliyuncs.com
OSS_STS_ENDPOINT=sts.cn-hangzhou.aliyuncs.com
OCR_AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OCR_AI_API_KEY=replace-with-real-key
OCR_AI_MODEL=qwen-vl-ocr-latest
TEXT_AI_BASE_URL=https://api.openai.com/v1
TEXT_AI_API_KEY=replace-with-openai-key
TEXT_AI_MODEL=gpt-5.4
TEXT_AI_STREAM=false
BATCH_VISION_AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
BATCH_VISION_AI_API_KEY=replace-with-real-key
BATCH_VISION_AI_MODEL=qwen-vl-max-latest
